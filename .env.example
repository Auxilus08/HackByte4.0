# ─── Database ──────────────────────────────────
# Use "db" as hostname when running via Docker Compose
# Use "localhost" if running backend directly on host
DATABASE_URL=postgresql+asyncpg://smartaccident:smartaccident_secret@db:5432/smartaccident_db

# ─── App / JWT ─────────────────────────────────
SECRET_KEY=change_me_in_production

# ─── Twilio Voice API (optional) ───────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Google Maps Geocoding API (optional) ──────
GOOGLE_MAPS_API_KEY=

# ─── Blockchain - Polygon Amoy (optional) ──────
WEB3_PROVIDER_URL=https://rpc-amoy.polygon.technology
REWARD_CONTRACT_ADDRESS=
DEPLOYER_PRIVATE_KEY=
